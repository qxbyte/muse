{
  "name": "@qxbyte/muse",
  "version": "0.1.0",
  "description": "A TypeScript agent CLI built around OpenAI-compatible APIs. First-class support for self-hostable and Chinese LLMs (DeepSeek, Qwen, Kimi, GLM, Ollama, MiMo).",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/qxbyte/muse#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qxbyte/muse.git"
  },
  "bugs": {
    "url": "https://github.com/qxbyte/muse/issues"
  },
  "keywords": [
    "agent",
    "cli",
    "llm",
    "tui",
    "ink",
    "deepseek",
    "qwen",
    "ollama",
    "openai-compatible"
  ],
  "bin": {
    "muse": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node ./dist/cli.js",
    "muse": "node ./dist/cli.js",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/openai-compatible": "^0.1.0",
    "ai": "^4.0.0",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "execa": "^9.5.0",
    "fast-glob": "^3.3.2",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
